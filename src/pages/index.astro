---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import profilePic from '../assets/Topias-R.jpg';
import serveriLogo from '../assets/Serveri_logo_musta_valkoinentausta(3).svg';
import uefLogo from '../assets/University_of_Eastern_Finland_logo.svg';
import spaceioImg from '../assets/Projects/Spaceio.png';
import uiresearchImg from '../assets/Projects/uiresearch.png';
import homelabImg from '../assets/Projects/homelab.png';
import lunchImg from '../assets/Projects/lunchscreen.jpg';
import portfolioImg from '../assets/Projects/portfolio.png';
import recipeImg from '../assets/Projects/recipeapp.png';
import { translations } from '../i18n';

const fi = translations.fi;
const en = translations.en;

const techIcons: Record<string, string> = {
	'TypeScript': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg',
	'JavaScript': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg',
	'Python': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg',
	'Java': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg',
	'C#': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/csharp/csharp-original.svg',
	'Kotlin': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/kotlin/kotlin-original.svg',
	'SQL': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/azuresqldatabase/azuresqldatabase-original.svg',
	'React': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg',
	'Vue': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vuejs/vuejs-original.svg',
	'HTML/CSS': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg',
	'Node.js': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg',
	'Linux': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/linux/linux-original.svg',
	'Docker': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg',
	'Git': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg',
	'CI/CD': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/githubactions/githubactions-original.svg',
	'Azure': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/azure/azure-original.svg',
	'Astro': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg',
	'Suomi': 'https://flagcdn.com/fi.svg',
	'Englanti': 'https://flagcdn.com/gb.svg'
};
---

<Layout title="Topias Remes | Portfolio">

	<!-- ═══════════════════ HEADER ═══════════════════ -->
	<header class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-20 relative">

		<!-- Language toggle (top right) -->
		<div class="absolute top-0 right-0">
			<div class="lang-toggle" id="lang-toggle">
				<button type="button" data-set-lang="fi" class="active">FI</button>
				<button type="button" data-set-lang="en">EN</button>
			</div>
		</div>

		<Image
			src={profilePic}
			alt="Topias Remes"
			width={140}
			height={140}
			class="rounded-full ring-2 ring-zinc-700 object-cover shrink-0"
		/>
		<div class="text-center sm:text-left">
			<h1 class="text-3xl md:text-4xl font-bold text-white tracking-tight mb-2 drop-shadow-[0_0_15px_rgba(255,255,255,0.15)]">
				Topias Remes
			</h1>
			<p data-lang="en" class="text-lg text-zinc-400 mb-4 hidden">
				{en.subtitle}
				<span class="text-zinc-600">&middot;</span> {en.location}
			</p>
			<p data-lang="fi" class="text-lg text-zinc-400 mb-4">
				{fi.subtitle}
				<span class="text-zinc-600">&middot;</span> {fi.location}
			</p>
			<div class="flex items-center justify-center sm:justify-start gap-5 text-sm">
				<a href="https://github.com/RemesTop" target="_blank" rel="noopener noreferrer"
				   class="text-zinc-400 hover:text-white transition-colors flex items-center gap-1.5">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
						 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
						<path d="M9 18c-4.51 2-5-2-7-2" />
					</svg>
					GitHub
				</a>
				<a href="https://www.linkedin.com/in/topias-remes-377863347/" target="_blank" rel="noopener noreferrer"
				   class="text-zinc-400 hover:text-white transition-colors flex items-center gap-1.5">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
						 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
						<rect width="4" height="12" x="2" y="9" />
						<circle cx="4" cy="4" r="2" />
					</svg>
					LinkedIn
				</a>
				<button
					type="button"
					id="email-copy-header"
					class="text-zinc-400 hover:text-white transition-colors flex items-center gap-1.5 cursor-pointer"
					title="Copy email"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
						 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect width="20" height="16" x="2" y="4" rx="2" />
						<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
					</svg>
					<span id="email-copy-header-text">topiasre@gmail.com</span>
				</button>
			</div>
		</div>
	</header>

	<!-- ═══════════════════ ABOUT ═══════════════════ -->
	<section class="mb-16">
		<h2 data-lang="en" class="text-xl font-semibold text-white mb-6 tracking-tight hidden">{en.aboutHeading}</h2>
		<h2 data-lang="fi" class="text-xl font-semibold text-white mb-6 tracking-tight">{fi.aboutHeading}</h2>
		<p data-lang="en" class="text-zinc-400 leading-relaxed max-w-3xl whitespace-pre-wrap hidden">{en.about}</p>
		<p data-lang="fi" class="text-zinc-400 leading-relaxed max-w-3xl whitespace-pre-wrap">{fi.about}</p>
	</section>

	<!-- ═══════════════════ TECHNOLOGIES ═══════════════════ -->
	<section class="mb-16">
		<h2 data-lang="en" class="text-xl font-semibold text-white mb-6 tracking-tight hidden">{en.techHeading}</h2>
		<h2 data-lang="fi" class="text-xl font-semibold text-white mb-6 tracking-tight">{fi.techHeading}</h2>

		<div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
			<div>
				<p data-lang="en" class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-3 hidden">{en.techCategories.languages}</p>
				<p data-lang="fi" class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-3">{fi.techCategories.languages}</p>
				<div class="flex flex-wrap gap-2.5">
					{['TypeScript', 'JavaScript', 'Python', 'Java', 'C#', 'Kotlin', 'SQL', 'Suomi', 'Englanti'].map((t) => (
						<span class="tech-badge text-sm flex items-center gap-2 py-1.5 px-3">
							{techIcons[t] && <img src={techIcons[t]} alt={t} class="w-4 h-4 object-contain rounded-sm" />}
							{t === 'Suomi' ? (
								<>
									<span data-lang="fi">Suomi</span>
									<span data-lang="en" class="hidden">Finnish</span>
								</>
							) : t === 'Englanti' ? (
								<>
									<span data-lang="fi">Englanti</span>
									<span data-lang="en" class="hidden">English</span>
								</>
							) : (
								t
							)}
						</span>
					))}
				</div>
			</div>
			<div>
				<p data-lang="en" class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-3 hidden">{en.techCategories.frontend}</p>
				<p data-lang="fi" class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-3">{fi.techCategories.frontend}</p>
				<div class="flex flex-wrap gap-2.5">
					{['React', 'Vue', 'Astro', 'HTML/CSS'].map((t) => (
						<span class="tech-badge text-sm flex items-center gap-2 py-1.5 px-3">
							<img src={techIcons[t]} alt={t} class="w-4 h-4 object-contain" />
							{t}
						</span>
					))}
				</div>
			</div>
			<div>
				<p data-lang="en" class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-3 hidden">{en.techCategories.backend}</p>
				<p data-lang="fi" class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-3">{fi.techCategories.backend}</p>
				<div class="flex flex-wrap gap-2.5">
					{['Node.js', 'Linux', 'Docker', 'Git', 'CI/CD', 'Azure'].map((t) => (
						<span class="tech-badge text-sm flex items-center gap-2 py-1.5 px-3">
							<img src={techIcons[t]} alt={t} class="w-4 h-4 object-contain" />
							{t}
						</span>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ PROJECTS (BENTO GRID) ═══════════════════ -->
	<section class="mb-16">
		<h2 data-lang="en" class="text-xl font-semibold text-white mb-6 tracking-tight hidden">{en.projectsHeading}</h2>
		<h2 data-lang="fi" class="text-xl font-semibold text-white mb-6 tracking-tight">{fi.projectsHeading}</h2>

		<div class="bento-grid">
			<!-- UI Research App -->
			<ProjectCard
				titleEn={en.projects.uiresearch.title}
				titleFi={fi.projects.uiresearch.title}
				descriptionEn={en.projects.uiresearch.description}
				descriptionFi={fi.projects.uiresearch.description}
				tech={['Next.js', 'React', 'TypeScript', 'UI/UX Design']}
				repoUrl="https://github.com/RemesTop/UI-ResearchApp"
				liveUrl="https://web-tutkimus.vercel.app/"
				image={uiresearchImg}
				gridArea="uiresearch"
			/>

			<!-- Space Io -->
			<ProjectCard
				titleEn={en.projects.spaceio.title}
				titleFi={fi.projects.spaceio.title}
				descriptionEn={en.projects.spaceio.description}
				descriptionFi={fi.projects.spaceio.description}
				tech={['TypeScript', 'Node.js', 'Socket.IO', 'Phaser 3']}
				repoUrl="https://github.com/Jeb4dev/space-io"
				image={spaceioImg}
				gridArea="spaceio"
			/>

			<!-- Campus Lunch Display -->
			<ProjectCard
				titleEn={en.projects.lunch.title}
				titleFi={fi.projects.lunch.title}
				descriptionEn={en.projects.lunch.description}
				descriptionFi={fi.projects.lunch.description}
				tech={['Vue.js', 'SQLite', 'Raspberry Pi']}
				repoUrl="https://github.com/serveri/ruoka_infotaulu"
				liveUrl="https://lunch.serveriry.fi/"
				image={lunchImg}
				gridArea="lunch"
			/>

			<!-- Recipe App -->
			<ProjectCard
				titleEn={en.projects.recipe.title}
				titleFi={fi.projects.recipe.title}
				descriptionEn={en.projects.recipe.description}
				descriptionFi={fi.projects.recipe.description}
				tech={['Next.js', 'DatoCMS', 'Tailwind CSS']}
				repoUrl="https://github.com/Jeb4dev/recipeapp"
				image={recipeImg}
				gridArea="recipe"
			/>

			<!-- Homelab Infrastructure -->
			<ProjectCard
				titleEn={en.projects.homelab.title}
				titleFi={fi.projects.homelab.title}
				descriptionEn={en.projects.homelab.description}
				descriptionFi={fi.projects.homelab.description}
				tech={['Linux', 'Ansible', 'Docker', 'Networking']}
				image={homelabImg}
				gridArea="homelab"
			/>

			<!-- Web Portfolio -->
			<ProjectCard
				titleEn={en.projects.portfolio.title}
				titleFi={fi.projects.portfolio.title}
				descriptionEn={en.projects.portfolio.description}
				descriptionFi={fi.projects.portfolio.description}
				tech={['Astro', 'Tailwind CSS', 'TypeScript']}
				repoUrl="https://github.com/RemesTop/Portfolio"
				image={portfolioImg}
				gridArea="portfolio"
			/>
		</div>
	</section>

	<!-- ═══════════════════ EXPERIENCE & EDUCATION ═══════════════════ -->
	<section class="mb-16">
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<!-- Experience -->
			<div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6 sm:p-8 flex flex-col h-full">
				<h2 data-lang="en" class="text-xl sm:text-2xl font-bold text-white mb-8 tracking-tight hidden">{en.experienceHeading}</h2>
				<h2 data-lang="fi" class="text-xl sm:text-2xl font-bold text-white mb-8 tracking-tight">{fi.experienceHeading}</h2>

				<div class="relative border-l border-zinc-800 ml-4 space-y-10 flex-1">
					{en.experience.map((exp, i) => (
						<div class="relative pl-8">
							{exp.company === 'Serveri ry' ? (
								<div class="absolute -left-5 top-0.5 bg-white rounded-full p-0 w-10 h-10 flex items-center justify-center ring-8 ring-zinc-950">
									<Image src={serveriLogo} alt="Serveri ry" class="w-full h-full object-contain" />
								</div>
							) : (
								<div class="absolute -left-1.5 top-2 w-3 h-3 rounded-full bg-zinc-700 ring-8 ring-zinc-950"></div>
							)}

							<div class="flex flex-col gap-1">
								<h3 class="text-base sm:text-lg font-semibold text-zinc-100">
									<span data-lang="en" class="hidden">{exp.title}</span>
									<span data-lang="fi">{fi.experience[i].title}</span>
								</h3>
								<div class="text-zinc-400 font-medium text-sm mb-2">{exp.company} <span class="text-zinc-600 font-normal mx-1">&middot;</span> 
									<span data-lang="en" class="hidden">{exp.date}</span>
									<span data-lang="fi">{fi.experience[i].date}</span>
								</div>
								<p class="text-sm text-zinc-400 leading-relaxed">
									<span data-lang="en" class="hidden">
										{exp.description}
										{i === 0 && (
											<> (<a href="https://serveriry.fi" target="_blank" rel="noopener noreferrer" class="underline decoration-zinc-700 hover:decoration-zinc-400 hover:text-zinc-200 transition-colors">serveriry.fi</a>)</>
										)}
									</span>
									<span data-lang="fi">
										{fi.experience[i].description}
										{i === 0 && (
											<> (<a href="https://serveriry.fi" target="_blank" rel="noopener noreferrer" class="underline decoration-zinc-700 hover:decoration-zinc-400 hover:text-zinc-200 transition-colors">serveriry.fi</a>)</>
										)}
									</span>
								</p>
							</div>
						</div>
					))}
				</div>
			</div>

			<!-- Education -->
			<div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6 sm:p-8 flex flex-col h-full">
				<h2 data-lang="en" class="text-xl sm:text-2xl font-bold text-white mb-8 tracking-tight hidden">{en.educationHeading}</h2>
				<h2 data-lang="fi" class="text-xl sm:text-2xl font-bold text-white mb-8 tracking-tight">{fi.educationHeading}</h2>

				<div class="relative border-l border-zinc-800 ml-4 space-y-10 flex-1">
					{en.education.map((edu, i) => (
						<div class="relative pl-8">
							{edu.school.includes('Itä-Suomen yliopisto') || edu.school.includes('University of Eastern Finland') ? (
								<div class="absolute -left-5 top-0.5 bg-zinc-950 rounded-full p-1.5 w-10 h-10 flex items-center justify-center ring-8 ring-zinc-950 border border-zinc-800">
									<Image src={uefLogo} alt="UEF" class="w-full h-full object-contain brightness-0 invert" />
								</div>
							) : (
								<div class="absolute -left-1.5 top-2 w-3 h-3 rounded-full bg-zinc-700 ring-8 ring-zinc-950"></div>
							)}

							<div class="flex flex-col gap-1">
								<h3 class="text-base sm:text-lg font-semibold text-zinc-100">
									<span data-lang="en" class="hidden">{edu.degree}</span>
									<span data-lang="fi">{fi.education[i].degree}</span>
								</h3>
								<div class="text-zinc-400 font-medium text-sm mb-2">{edu.school} <span class="text-zinc-600 font-normal mx-1">&middot;</span> 
									<span data-lang="en" class="hidden">{edu.date}</span>
									<span data-lang="fi">{fi.education[i].date}</span>
								</div>
								{edu.note && (
									<p class="text-sm text-zinc-400 leading-relaxed whitespace-pre-line mt-1">
										<span data-lang="en" class="hidden">{edu.note}</span>
										<span data-lang="fi">{fi.education[i].note}</span>
									</p>
								)}
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ CTA ═══════════════════ -->
	<section class="mb-16 text-center">
		<div class="rounded-xl border border-zinc-800 bg-zinc-900/60 px-8 py-10">
			<h2 data-lang="en" class="text-xl font-semibold text-white mb-3 tracking-tight hidden">{en.ctaHeading}</h2>
			<h2 data-lang="fi" class="text-xl font-semibold text-white mb-3 tracking-tight">{fi.ctaHeading}</h2>
			<p data-lang="en" class="text-zinc-400 mb-6 max-w-md mx-auto hidden">{en.ctaText}</p>
			<p data-lang="fi" class="text-zinc-400 mb-6 max-w-md mx-auto">{fi.ctaText}</p>
			<a
				href="https://www.linkedin.com/in/topias-remes-377863347/"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 rounded-full bg-zinc-100 text-zinc-900 px-6 py-2.5 text-sm font-semibold hover:bg-white transition-colors"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
					 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
					<rect width="4" height="12" x="2" y="9" />
					<circle cx="4" cy="4" r="2" />
				</svg>
				<span data-lang="en" class="hidden">{en.ctaButton}</span>
				<span data-lang="fi">{fi.ctaButton}</span>
			</a>
			<button
				type="button"
				id="email-copy-cta"
				class="inline-flex items-center gap-2 rounded-full border border-zinc-700 bg-transparent text-zinc-300 px-6 py-2.5 text-sm font-semibold hover:border-zinc-500 hover:text-white transition-colors cursor-pointer mt-4 sm:mt-0 sm:ml-4"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
					 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect width="20" height="16" x="2" y="4" rx="2" />
					<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
				</svg>
				<span id="email-copy-cta-text">topiasre@gmail.com</span>
			</button>
		</div>
	</section>

	<!-- ═══════════════════ FOOTER ═══════════════════ -->
	<footer class="border-t border-zinc-800 pt-8 text-center text-xs text-zinc-600">
		<p>&copy; 2026 Topias Remes</p>
	</footer>

</Layout>

<script>
	function initLang() {
		const saved = localStorage.getItem('portfolio-lang') || 'fi';
		setLang(saved);

		const toggle = document.getElementById('lang-toggle');
		if (toggle) {
			toggle.addEventListener('click', (e) => {
				const btn = (e.target as HTMLElement).closest('button[data-set-lang]');
				if (!btn) return;
				const lang = btn.getAttribute('data-set-lang');
				if (lang) setLang(lang);
			});
		}
	}

	function setLang(lang: string) {
		localStorage.setItem('portfolio-lang', lang);
		document.documentElement.setAttribute('lang', lang);

		// Toggle visibility of all data-lang elements
		document.querySelectorAll('[data-lang]').forEach((el) => {
			const elLang = el.getAttribute('data-lang');
			if (elLang === lang) {
				el.classList.remove('hidden');
			} else {
				el.classList.add('hidden');
			}
		});

		// Update toggle button active states
		document.querySelectorAll('#lang-toggle button').forEach((btn) => {
			if (btn.getAttribute('data-set-lang') === lang) {
				btn.classList.add('active');
			} else {
				btn.classList.remove('active');
			}
		});
	}

	// Run on initial load
	initLang();

	// Also run after Astro view transitions (if any)
	document.addEventListener('astro:after-swap', initLang);

	// Email copy-to-clipboard
	function copyEmail(buttonId: string, textId: string) {
		const btn = document.getElementById(buttonId);
		const textEl = document.getElementById(textId);
		if (!btn || !textEl) return;

		btn.addEventListener('click', async () => {
			await navigator.clipboard.writeText('topiasre@gmail.com');
			const lang = localStorage.getItem('portfolio-lang') || 'fi';
			const copiedText = lang === 'fi' ? 'Kopioitu!' : 'Copied!';
			const original = textEl.textContent;
			textEl.textContent = copiedText;
			setTimeout(() => { textEl.textContent = original; }, 2000);
		});
	}

	copyEmail('email-copy-header', 'email-copy-header-text');
