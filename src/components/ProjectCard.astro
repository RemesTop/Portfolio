---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
	titleEn: string;
	titleFi: string;
	descriptionEn: string;
	descriptionFi: string;
	tech: string[];
	repoUrl?: string;
	liveUrl?: string;
	gridArea?: string;
	image?: ImageMetadata;
}

const {
	titleEn,
	titleFi,
	descriptionEn,
	descriptionFi,
	tech,
	repoUrl,
	liveUrl,
	gridArea,
	image,
} = Astro.props;
---

<article
	class="group relative rounded-xl border border-zinc-800 bg-zinc-900/60 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-zinc-600 hover:shadow-[0_4px_24px_rgba(0,0,0,0.4)]"
	style={gridArea ? `grid-area: ${gridArea}` : ''}
>
	<div class="rounded-t-xl overflow-hidden bg-zinc-800/40 border-b border-zinc-800">
		{/* Faux Browser Header */}
		<div class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/80">
			<div class="w-2.5 h-2.5 rounded-full bg-red-500/60"></div>
			<div class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></div>
			<div class="w-2.5 h-2.5 rounded-full bg-green-500/60"></div>
		</div>
		{/* Browser Content */}
		<div class="overflow-hidden bg-zinc-950">
			{image ? (
				<Image
					src={image}
					alt=""
					class="project-img w-full h-[160px] object-cover object-top transition-all duration-700 group-hover:scale-105"
					loading="lazy"
				/>
			) : (
				<img
					src="/placeholder.jpg"
					alt=""
					class="project-img w-full h-[160px] object-cover object-top transition-all duration-700 group-hover:scale-105"
					loading="lazy"
				/>
			)}
		</div>
	</div>
	<div class="p-5">
		<div class="flex items-start justify-between gap-4 mb-2">
			<h3 data-lang="en" class="text-base font-semibold text-zinc-100 group-hover:text-white transition-colors hidden">
				{titleEn}
			</h3>
			<h3 data-lang="fi" class="text-base font-semibold text-zinc-100 group-hover:text-white transition-colors">
				{titleFi}
			</h3>
			{(repoUrl || liveUrl) && (
				<div class="flex items-center gap-3 shrink-0">
					{repoUrl && (
						<a
							href={repoUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="text-zinc-500 hover:text-zinc-200 transition-colors"
							aria-label={`${titleEn} source code on GitHub`}
							title="Source Code"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
								 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
								<path d="M9 18c-4.51 2-5-2-7-2" />
							</svg>
						</a>
					)}
					{liveUrl && (
						<a
							href={liveUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="flex items-center gap-1.5 text-xs font-medium text-zinc-300 hover:text-white transition-colors bg-zinc-800/80 hover:bg-zinc-700 px-2.5 py-1.5 rounded border border-zinc-700"
							aria-label={`${titleEn} live demo`}
						>
							<span data-lang="fi">Linkki</span>
							<span data-lang="en" class="hidden">View</span>
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
								 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M15 3h6v6" />
								<path d="M10 14 21 3" />
								<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
							</svg>
						</a>
					)}
				</div>
			)}
		</div>

		<p data-lang="en" class="text-sm leading-relaxed text-zinc-400 mb-3">{descriptionEn}</p>
		<p data-lang="fi" class="text-sm leading-relaxed text-zinc-400 mb-3 hidden">{descriptionFi}</p>

		<div class="flex flex-wrap gap-1.5">
			{tech.map((t) => (
				<span class="tech-badge">{t}</span>
			))}
		</div>
	</div>
</article>
