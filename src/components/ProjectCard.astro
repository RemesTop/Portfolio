---
interface Props {
	title: string;
	descriptionEn: string;
	descriptionFi: string;
	tech: string[];
	repoUrl?: string;
	liveUrl?: string;
	size?: 'large' | 'small';
	gridArea?: string;
}

const {
	title,
	descriptionEn,
	descriptionFi,
	tech,
	repoUrl,
	liveUrl,
	size = 'small',
	gridArea,
} = Astro.props;

const isLarge = size === 'large';
---

<article
	class:list={[
		'group relative rounded-xl border border-zinc-800 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-zinc-600 hover:shadow-[0_4px_24px_rgba(0,0,0,0.4)]',
		isLarge ? 'card-large' : 'card-small bg-zinc-900/60',
	]}
	style={gridArea ? `grid-area: ${gridArea}` : ''}
>
	{isLarge ? (
		<>
			{/* Background image for large cards */}
			<img
				src="/placeholder.jpg"
				alt=""
				class="card-bg"
				loading="lazy"
			/>
			<div class="card-overlay"></div>
			<div class="card-content p-6 pt-24">
				{/* Links */}
				<div class="flex items-start justify-between gap-4 mb-3">
					<h3 class="text-xl font-bold text-white tracking-tight">
						{title}
					</h3>
					{(repoUrl || liveUrl) && (
						<div class="flex items-center gap-3 shrink-0 pt-0.5">
							{repoUrl && (
								<a
									href={repoUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="text-zinc-400 hover:text-white transition-colors"
									aria-label={`${title} source code on GitHub`}
									title="Source Code"
								>
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
										 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
										<path d="M9 18c-4.51 2-5-2-7-2" />
									</svg>
								</a>
							)}
							{liveUrl && (
								<a
									href={liveUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="text-zinc-400 hover:text-white transition-colors"
									aria-label={`${title} live demo`}
									title="Live Demo"
								>
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
										 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M15 3h6v6" />
										<path d="M10 14 21 3" />
										<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
									</svg>
								</a>
							)}
						</div>
					)}
				</div>

				<p data-lang="en" class="text-sm leading-relaxed text-zinc-300 mb-4">{descriptionEn}</p>
				<p data-lang="fi" class="text-sm leading-relaxed text-zinc-300 mb-4 hidden">{descriptionFi}</p>

				<div class="flex flex-wrap gap-1.5">
					{tech.map((t) => (
						<span class="tech-badge">{t}</span>
					))}
				</div>
			</div>
		</>
	) : (
		<>
			{/* Top image for small cards */}
			<img
				src="/placeholder.jpg"
				alt=""
				class="card-img-top"
				loading="lazy"
			/>
			<div class="p-5">
				<div class="flex items-start justify-between gap-4 mb-2">
					<h3 class="text-base font-semibold text-zinc-100 group-hover:text-white transition-colors">
						{title}
					</h3>
					{(repoUrl || liveUrl) && (
						<div class="flex items-center gap-3 shrink-0">
							{repoUrl && (
								<a
									href={repoUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="text-zinc-500 hover:text-zinc-200 transition-colors"
									aria-label={`${title} source code on GitHub`}
									title="Source Code"
								>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
										 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
										<path d="M9 18c-4.51 2-5-2-7-2" />
									</svg>
								</a>
							)}
							{liveUrl && (
								<a
									href={liveUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="text-zinc-500 hover:text-zinc-200 transition-colors"
									aria-label={`${title} live demo`}
									title="Live Demo"
								>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
										 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M15 3h6v6" />
										<path d="M10 14 21 3" />
										<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
									</svg>
								</a>
							)}
						</div>
					)}
				</div>

				<p data-lang="en" class="text-sm leading-relaxed text-zinc-400 mb-3">{descriptionEn}</p>
				<p data-lang="fi" class="text-sm leading-relaxed text-zinc-400 mb-3 hidden">{descriptionFi}</p>

				<div class="flex flex-wrap gap-1.5">
					{tech.map((t) => (
						<span class="tech-badge">{t}</span>
					))}
				</div>
			</div>
		</>
	)}
</article>
